# MCPlexer Configuration
MCPLEXER_MODE=stdio          # stdio | http
MCPLEXER_HTTP_ADDR=127.0.0.1:3333 # HTTP listen address (http mode). WARNING: binding to 0.0.0.0 exposes the API to your network — use a reverse proxy with TLS for internet access. See README "Network exposure".
MCPLEXER_TRUSTED_HOSTS=      # Comma-separated browser Origin hostnames, e.g. my-mac.tailnet.ts.net
MCPLEXER_DB_DRIVER=sqlite    # sqlite | postgres
MCPLEXER_DB_DSN=mcplexer.db  # SQLite file path or Postgres connection string
MCPLEXER_AGE_KEY=            # Path to age identity file for secret encryption
MCPLEXER_CONFIG=mcplexer.yaml # Path to YAML config file
MCPLEXER_LOG_LEVEL=info      # debug | info | warn | error
MCPLEXER_SLIM_TOOLS=true     # Minify tool schemas to reduce context window usage
MCPLEXER_CODEX_DYNAMIC_TOOL_COMPAT=true  # Auto-include dynamic tools for Codex sessions
