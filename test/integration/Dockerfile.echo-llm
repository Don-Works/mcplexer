# syntax=docker/dockerfile:1.6
#
# Minimal OpenAI-compatible echo server. Returns a fixed valid chat
# completion so the worker run test has a deterministic positive path
# without depending on a real model provider.
FROM golang:1.25-alpine AS build

WORKDIR /src
# go run/build of a single-file program needs a module to satisfy Go 1.25.
RUN go mod init echo-llm
COPY echo-llm.go ./
RUN CGO_ENABLED=0 go build -o /out/echo-llm echo-llm.go

FROM alpine:3.20 AS runtime
# wget is required by the docker-compose healthcheck.
RUN apk add --no-cache wget
COPY --from=build /out/echo-llm /echo-llm
EXPOSE 8080
ENTRYPOINT ["/echo-llm"]
